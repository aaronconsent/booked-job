    {"id": "title", "text": "WHERE CUSTOMERS FIND YOU", "sub": "COURSE 3", "text_y": 105, "emph": "CUSTOMERS", "mood": "neutral",
     "vo": "Customers don't find you by magic. They don't stumble onto your truck and feel a connection. They come through doors.",
     "char": {"x": 400, "y": 470, "scale": 0.62, "hat": "hardhat", "tool": "wrench", "gesture_at": 9},
     "assets": [{"id": "magnet", "w": 240, "x": 1360, "y": 600, "anim": "drawOn", "t": 0.5, "sfx": "pop"}]},
    {"id": "onlyfive", "text": "ONLY FIVE DOORS", "text_y": 120, "emph": "FIVE", "mood": "neutral",
     "vo": "And here's the thing nobody tells you. There are only five of them. Five doors, that's it. Once you can see all five, you stop throwing money at random and start running this like a business.",
     "char": {"x": 340, "y": 460, "scale": 0.6, "hat": "hardhat", "tool": "wrench"},
     "assets": [{"id": "door", "w": 260, "x": 1300, "y": 640, "anim": "drawOn", "t": 0.5, "sfx": "thunk", "label": "JUST 5"}]},

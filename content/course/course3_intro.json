    {"id": "threecost", "text": "THREE COST MONEY", "text_y": 120, "emph": "MONEY",
     "vo": "The other three, ads, lead apps, paid placement, those cost real money.",
     "assets": [{"id": "megaphone", "w": 220, "x": 480, "y": 600, "anim": "drawOn", "t": 0.4, "label": "ADS"},
                {"id": "leadapp", "w": 200, "x": 960, "y": 600, "anim": "popIn", "t": 1.8, "sfx": "ping", "label": "LEAD APPS"},

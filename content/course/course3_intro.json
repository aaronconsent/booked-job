    {"id": "timebomb", "text": "100% ONE APP = TIME BOMB", "text_y": 105, "emph": "BOMB", "wash": "yellow",
     "transition_in": "whip",
     "vo": "Now here's the nightmare. The guy who gets a hundred percent of his work from one app. One door. He's not a business owner, he's a renter.",
     "assets": [{"id": "eggsbasket", "w": 360, "x": 700, "y": 600, "anim": "drawOn", "t": 0.4, "label": "ALL OF IT, ONE APP"},
                {"id": "leadapp", "w": 220, "x": 1380, "y": 600, "anim": "popIn", "t": 3.0, "sfx": "buzz", "label": "ONE DOOR"}]},
    {"id": "deadphone", "text": "ONE DOOR ISN'T A STRATEGY", "text_y": 110, "emph": "STRATEGY", "mood": "frustrated",
     "vo": "The day that app jacks its prices, or changes the rules, or just shuts his account off with no warning, his phone goes dead silent. I've watched it happen. One door is not a strategy. It's a time bomb.",
     "char": {"x": 320, "y": 460, "scale": 0.58, "hat": "hardhat"},
     "assets": [{"id": "phonemap", "w": 280, "x": 1300, "y": 600, "anim": "drawOn", "t": 0.4, "mark": "x", "sfx": "buzz", "label": "DEAD SILENT"}]},
